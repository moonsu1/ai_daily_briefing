# ===== LLM API (둘 중 하나만 설정해도 됩니다) =====
# 기본값: Gemini (무료 티어 250 req/일)
GEMINI_API_KEY=your_gemini_api_key_here

# 대안: Claude Haiku 4.5 (더 높은 품질)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 사용할 LLM 제공자: "gemini" 또는 "claude"
LLM_PROVIDER=gemini

# ===== 이메일 설정 =====
# Gmail App Password 방식 (2단계 인증 필요)
# 발급 경로: Google 계정 → 보안 → 앱 비밀번호
EMAIL_SENDER=moonsu159@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECEIVER=moonsu159@gmail.com

# ===== 스케줄 설정 =====
# 매일 브리핑 발송 시각 (24시간 형식, KST 기준)
BRIEFING_HOUR=7
BRIEFING_MINUTE=0
